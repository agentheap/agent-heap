# Agent Heap — Environment Configuration
#
# Network toggle — switch between testnet (default) and mainnet:
#   ARBITRUM_NETWORK=sepolia    # testnet (default, safe for testing)
#   ARBITRUM_NETWORK=mainnet    # REAL MONEY — be careful!
#
# === Sepolia testnet ===
# Get free testnet ETH from:
#   https://faucet.quicknode.com/arbitrum/sepolia
#   https://www.alchemy.com/faucets/arbitrum-sepolia
#   https://faucets.chain.link/arbitrum-sepolia
#
# === Arbitrum One mainnet ===
# Fund your wallet with real ETH from any CEX or bridge:
#   https://bridge.arbitrum.io/
#

ARBITRUM_NETWORK=sepolia
BASE_RPC=https://sepolia.base.org
NVIDIA_NIM_API_KEY=
DATABASE_URL=sqlite:///agent-heap.db

# Your agent wallet private key.
# Generate with: ARBITRUM_NETWORK=mainnet uv run wallet generate
# ⚠️  NEVER commit this file with a real private key!
PRIVATE_KEY=

# Wallet JSON path (auto-generated)
WALLET_PATH=data/agent_wallet.json
