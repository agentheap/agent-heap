# Agent Heap — Environment Configuration
#
# Get testnet ETH from Arbitrum Sepolia faucets:
#   https://faucet.quicknode.com/arbitrum/sepolia
#   https://www.alchemy.com/faucets/arbitrum-sepolia
#   https://faucets.chain.link/arbitrum-sepolia
#
# Agent wallet address (generate with: uv run python -m wallet.setup --generate):
# AGENT_ADDRESS=0x608fF2AB930475B3301C4061c0E8018cC15A2cBC

ARBITRUM_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_RPC=https://sepolia.base.org
NVIDIA_NIM_API_KEY=
DATABASE_URL=sqlite:///agent-heap.db

# Generate and set: uv run python -m wallet.setup --generate
# Then copy the private key here:
PRIVATE_KEY=

# Wallet JSON path (auto-generated)
WALLET_PATH=data/agent_wallet.json
