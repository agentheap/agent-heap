# Agent Heap — Environment Configuration

# === Arbitrum (required for live execution) ===
ARBITRUM_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_RPC=https://sepolia.base.org

# === LLM Provider (choose one) ===
# Set the model name — LiteLLM handles all providers
# Examples:
#   openai:        gpt-4o, gpt-4o-mini, o3-mini
#   anthropic:     claude-sonnet-4-20250514, claude-haiku-4-20251001
#   google:        gemini/gemini-2.0-flash, gemini/gemini-2.0-flash-lite
#   groq:          groq/llama-3.3-70b-versatile, groq/deepseek-r1-distill-llama-70b
#   mistral:       mistral/mistral-large-latest
#   openrouter:    openrouter/anthropic/claude-sonnet-4
#   deepseek:      deepseek/deepseek-chat
#   together:      together_ai/meta-llama/Llama-3.3-70B-Instruct-Turbo
LLM_MODEL=

# Set the API key for your chosen provider:
# OpenAI / OpenRouter / DeepSeek
OPENAI_API_KEY=
# Anthropic
ANTHROPIC_API_KEY=
# Google Gemini (use GOOGLE_APPLICATION_CREDENTIALS or GEMINI_API_KEY)
GEMINI_API_KEY=
# Groq
GROQ_API_KEY=
# Mistral
MISTRAL_API_KEY=
# Together AI
TOGETHER_API_KEY=

# === Wallet (required for real execution) ===
# Use EITHER PRIVATE_KEY (raw, less secure) OR KEYSTORE_FILE + KEYSTORE_PASSPHRASE (recommended)
PRIVATE_KEY=
# KEYSTORE_FILE=wallet.json
# KEYSTORE_PASSPHRASE=

# === Security Limits ===
# MAX_TX_AMOUNT=10.0          # Max USDC per single transaction
# DAILY_TX_LIMIT=50.0         # Max USDC per day across all transactions
# MAX_TX_PER_HOUR=10          # Max transactions per hour (rate limiting)

# === Database ===
DATABASE_URL=sqlite:///agent-heap.db
